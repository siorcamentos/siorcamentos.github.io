{
  "versao": "2.0",
  "descricao": "Fluxos de conversa adaptativos para orçamento de obras - Construtor PRO",
  "fluxos": {
    "fundacao_baldrame": {
      "categoria_servico": "fundacao",
      "unidade_base": "metro_linear",
      "complexidade": "media",
      "precisa_projeto": true,
      "palavras_chave": [
        "fazer baldrame",
        "viga baldrame",
        "alicerce",
        "fundação",
        "base da casa"
      ],
      "saudacao_ia": "Beleza, Mestre! Vamos levantar os dados desse baldrame.",
      "confirmacao_servico": "Você quer orçar a execução de viga baldrame de fundação, certo?",
      "variaveis_iniciais": {
        "secao_padrao_largura": 20,
        "secao_padrao_altura": 30
      },
      "perguntas": [
        {
          "id": "metros_lineares",
          "tipo": "numero",
          "rotulo": "Quantos metros lineares de baldrame serão executados?",
          "variavel": "metros_lineares",
          "obrigatorio": true,
          "validacao": ">0"
        },
        {
          "id": "secao",
          "tipo": "grupo",
          "rotulo": "Seção da viga",
          "perguntas": [
            {
              "id": "largura",
              "tipo": "numero",
              "rotulo": "Largura (cm)",
              "variavel": "largura_cm",
              "padrao": 20,
              "sugestao": "15, 20, 25"
            },
            {
              "id": "altura",
              "tipo": "numero",
              "rotulo": "Altura (cm)",
              "variavel": "altura_cm",
              "padrao": 30,
              "sugestao": "25, 30, 35"
            }
          ]
        },
        {
          "id": "terreno_escavado",
          "tipo": "booleano",
          "rotulo": "O terreno já está escavado e nivelado?",
          "variavel": "terreno_escavado",
          "padrao": false
        },
        {
          "id": "concreto_tipo",
          "tipo": "escolha",
          "rotulo": "O concreto será feito na obra ou usinado?",
          "variavel": "concreto_tipo",
          "opcoes": [
            { "id": "obra", "nome": "Feito na obra" },
            { "id": "usinado", "nome": "Usinado" }
          ],
          "padrao": "obra"
        },
        {
          "id": "formas",
          "tipo": "booleano",
          "rotulo": "Vai precisar de formas de madeira?",
          "variavel": "precisa_formas",
          "padrao": true
        }
      ],
      "acoes": [
        {
          "tipo": "calcular",
          "variavel": "volume_concreto_m3",
          "formula": "metros_lineares * (largura_cm/100) * (altura_cm/100)"
        },
        {
          "tipo": "calcular",
          "variavel": "cimento_sacos",
          "formula": "volume_concreto_m3 * 7"
        },
        {
          "tipo": "calcular",
          "variavel": "aco_kg",
          "formula": "metros_lineares * 8"
        },
        {
          "tipo": "adicionar_servico",
          "servico_id": "baldrame",
          "quantidade": "metros_lineares",
          "unidade": "m",
          "parametros": {
            "secao": "{largura_cm}x{altura_cm}",
            "concreto_tipo": "{concreto_tipo}",
            "formas_inclusas": "{precisa_formas}"
          }
        },
        {
          "tipo": "condicional",
          "condicao": "terreno_escavado == false",
          "entao": {
            "tipo": "adicionar_servico",
            "servico_id": "escavacao_vala",
            "quantidade": "metros_lineares",
            "unidade": "m"
          }
        },
        {
          "tipo": "condicional",
          "condicao": "concreto_tipo == 'obra'",
          "entao": {
            "tipo": "adicionar_servico",
            "servico_id": "concreto_obra",
            "quantidade": "volume_concreto_m3",
            "unidade": "m³"
          }
        },
        {
          "tipo": "condicional",
          "condicao": "precisa_formas",
          "entao": {
            "tipo": "adicionar_servico",
            "servico_id": "forma_madeira",
            "quantidade": "metros_lineares * 2",
            "unidade": "m²",
            "observacao": "Área de forma para uma face? Ajustar conforme necessidade."
          }
        }
      ],
      "dica_mestre": "Antes de concretar, confira alinhamento, nível e use espaçadores para garantir cobrimento da ferragem.",
      "alerta_tecnico": "A viga baldrame deve apoiar sobre lastro de concreto magro e respeitar cobrimento mínimo da armadura conforme NBR 6118.",
      "servicos_relacionados": [
        "escavacao_vala",
        "lastro_concreto",
        "impermeabilizacao_baldrame"
      ],
      "servico_id": "baldrame"
    },
    "alvenaria_vedacao": {
      "categoria_servico": "alvenaria",
      "unidade_base": "m2",
      "complexidade": "media",
      "precisa_projeto": true,
      "palavras_chave": [
        "levantar parede",
        "fazer parede",
        "alvenaria",
        "parede de tijolo",
        "muro",
        "casa",
        "construir casa"
      ],
      "saudacao_ia": "Tranquilo, Mestre! Vamos planejar a alvenaria da sua obra.",
      "confirmacao_servico": "Você quer orçar a elevação das paredes (alvenaria de vedação), certo?",
      "perguntas": [
        {
          "id": "area_construida",
          "tipo": "numero",
          "rotulo": "Qual a área total construída (m²)?",
          "variavel": "area_m2",
          "obrigatorio": true,
          "validacao": ">0"
        },
        {
          "id": "pe_direito",
          "tipo": "numero",
          "rotulo": "Qual o pé-direito (altura das paredes) em metros? (padrão: 2,70 m)",
          "variavel": "altura_parede_m",
          "padrao": 2.7,
          "validacao": ">0"
        },
        {
          "id": "tipo_bloco",
          "tipo": "escolha",
          "rotulo": "Qual o tipo de bloco?",
          "variavel": "tipo_bloco",
          "opcoes": [
            { "id": "ceramico_8f", "nome": "Cerâmico 8 furos (19x19x39)" },
            { "id": "concreto", "nome": "Bloco de concreto (14x19x39)" }
          ],
          "padrao": "ceramico_8f"
        },
        {
          "id": "portas",
          "tipo": "grupo_repetitivo",
          "rotulo": "Agora, liste as portas (uma por linha no formato: largura altura). Ex: 0.80 2.10",
          "variavel": "portas",
          "subperguntas": [
            { "id": "largura", "tipo": "numero", "rotulo": "Largura (m)" },
            { "id": "altura", "tipo": "numero", "rotulo": "Altura (m)" }
          ]
        },
        {
          "id": "janelas",
          "tipo": "grupo_repetitivo",
          "rotulo": "Liste as janelas (largura altura). Ex: 1.20 1.20",
          "variavel": "janelas",
          "subperguntas": [
            { "id": "largura", "tipo": "numero", "rotulo": "Largura (m)" },
            { "id": "altura", "tipo": "numero", "rotulo": "Altura (m)" }
          ]
        },
        {
          "id": "pilares",
          "tipo": "numero",
          "rotulo": "Quantos pilares intermediários (entre paredes) existem? Se não souber, digite 0 e calcularemos pelo vão máximo.",
          "variavel": "qtd_pilares",
          "padrao": 0
        },
        {
          "id": "tipo_coberta",
          "tipo": "escolha",
          "rotulo": "A casa terá laje ou telhado?",
          "variavel": "coberta",
          "opcoes": [
            { "id": "laje", "nome": "Laje" },
            { "id": "telhado", "nome": "Telhado" }
          ]
        },
        {
          "id": "reboco_duas_faces",
          "tipo": "booleano",
          "rotulo": "As paredes serão rebocadas nos dois lados?",
          "variavel": "reboco_duas_faces",
          "padrao": true
        }
      ],
      "acoes": [
        {
          "tipo": "calcular",
          "variavel": "area_paredes_bruta",
          "formula": "area_m2 * altura_parede_m * 2"
        },
        {
          "tipo": "calcular",
          "variavel": "area_aberturas",
          "formula": "soma(portas, 'largura*altura') + soma(janelas, 'largura*altura')"
        },
        {
          "tipo": "calcular",
          "variavel": "area_liquida",
          "formula": "area_paredes_bruta - area_aberturas"
        },
        {
          "tipo": "adicionar_servico",
          "servico_id": "alvenaria_tijolo_8furos",
          "quantidade": "area_liquida",
          "unidade": "m²",
          "parametros": {
            "tipo_bloco": "{tipo_bloco}",
            "altura_parede": "{altura_parede_m}"
          }
        },
        {
          "tipo": "condicional",
          "condicao": "reboco_duas_faces == true",
          "entao": {
            "tipo": "adicionar_servico",
            "servico_id": "reboco_interno",
            "quantidade": "area_liquida * 2",
            "unidade": "m²"
          }
        },
        {
          "tipo": "condicional",
          "condicao": "qtd_pilares > 0",
          "entao": {
            "tipo": "adicionar_servico",
            "servico_id": "pilar_concreto",
            "quantidade": "qtd_pilares * altura_parede_m",
            "unidade": "m",
            "parametros": { "secao": "15x25" }
          }
        },
        {
          "tipo": "condicional",
          "condicao": "coberta == 'laje'",
          "entao": {
            "tipo": "adicionar_servico",
            "servico_id": "laje_macica",
            "quantidade": "area_m2",
            "unidade": "m²"
          }
        },
        {
          "tipo": "condicional",
          "condicao": "coberta == 'telhado'",
          "entao": {
            "tipo": "iniciar_fluxo",
            "fluxo_id": "estrutura_telhado",
            "area": "area_m2"
          }
        }
      ],
      "dica_mestre": "Sempre confira prumo e nível das primeiras fiadas. Isso evita retrabalho e parede torta.",
      "alerta_tecnico": "Paredes longas devem possuir pilares e cintas de amarração para evitar fissuras.",
      "servicos_relacionados": [
        "chapisco",
        "reboco_interno",
        "reboco_externo",
        "cinta_amarração"
      ],
      "servico_id": "alvenaria_tijolo_8furos"
    },
